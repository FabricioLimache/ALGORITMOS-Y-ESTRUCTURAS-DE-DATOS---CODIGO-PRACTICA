package Mineria;

import java.io.File;
import java.io.FileNotFoundException;
import java.util.HashMap;
import java.util.Map;
import java.util.Scanner;
import java.util.Locale;

public class AnalizadorMinero {
    private Zona[][] terreno;
    private int filas;
    private int columnas;

    // Método para cargar los datos desde el archivo txt

    public void cargarDatos(String rutaArchivo) {
        try {
            Scanner scanner = new Scanner(new File(rutaArchivo));
            
            // ESTA ES LA LÍNEA MÁGICA QUE SOLUCIONA EL ERROR
            scanner.useLocale(Locale.US); 
            
            if (scanner.hasNextInt()) {
                filas = scanner.nextInt();
                columnas = scanner.nextInt();
                terreno = new Zona[filas][columnas];

                for (int i = 0; i < filas; i++) {
                    for (int j = 0; j < columnas; j++) {
                        if (scanner.hasNext()) {
                            String mineral = scanner.next();
                            double cantidad = scanner.nextDouble(); // ¡Aquí ya no fallará!
                            double pureza = scanner.nextDouble();
                            terreno[i][j] = new Zona(mineral, cantidad, pureza);
                        }
                    }
                }
            }
            scanner.close();
        } catch (FileNotFoundException e) {
            System.out.println("Archivo no encontrado: " + e.getMessage());
        }
    }
    // Método principal para analizar el terreno dado un k
    public void analizarTerreno(int k) {
        double maxValor = -1;
        int mejorFila = -1;
        int mejorColumna = -1;

        // Recorrer todas las posibles subregiones k x k
        for (int i = 0; i <= filas - k; i++) {
            for (int j = 0; j <= columnas - k; j++) {
                double valorActual = calcularValorSubregion(i, j, k);
                if (valorActual > maxValor) {
                    maxValor = valorActual;
                    mejorFila = i;
                    mejorColumna = j;
                }
            }
        }

        mostrarResultados(mejorFila, mejorColumna, k, maxValor);
    }

    // Calcula la suma de los valores económicos de una subregión
    private double calcularValorSubregion(int filaInicio, int colInicio, int k) {
        double suma = 0;
        for (int i = filaInicio; i < filaInicio + k; i++) {
            for (int j = colInicio; j < colInicio + k; j++) {
                suma += terreno[i][j].getValorEconomico();
            }
        }
        return suma;
    }

    // Imprime los resultados con el formato esperado
    private void mostrarResultados(int fila, int col, int k, double maxValor) {
        System.out.println("Región más valiosa encontrada:");
        System.out.println("Posición inicial: (" + fila + "," + col + ")");
        System.out.println("Tamaño de la región: " + k + "x" + k);
        System.out.println("Zonas analizadas:");

        Map<String, Integer> conteoMinerales = new HashMap<>();

        for (int i = fila; i < fila + k; i++) {
            for (int j = col; j < col + k; j++) {
                Zona z = terreno[i][j];
                System.out.println(z.toString());
                
                // Contar minerales para encontrar el predominante
                conteoMinerales.put(z.getTipoMineral(), conteoMinerales.getOrDefault(z.getTipoMineral(), 0) + 1);
            }
        }

        System.out.println("Valor total estimado: " + maxValor);

        // Determinar mineral predominante
        String mineralPredominante = "";
        int maxApariciones = 0;
        for (Map.Entry<String, Integer> entry : conteoMinerales.entrySet()) {
            if (entry.getValue() > maxApariciones) {
                maxApariciones = entry.getValue();
                mineralPredominante = entry.getKey();
            }
        }
        System.out.println("Mineral predominante en la región: " + mineralPredominante);
    }
}